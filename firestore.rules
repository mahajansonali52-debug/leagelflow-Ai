rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isSuperAdmin() {
      return request.auth != null && 
        (getUserData().role == 'Super Admin' || getUserData().premiumLifetime == true);
    }
    
    function isPremiumUser() {
      return request.auth != null && 
        (getUserData().premiumLifetime == true || getUserData().plan == 'Pro' || getUserData().plan == 'Law Firm');
    }

    match /users/{userId} {
      allow read, write: if request.auth != null && (request.auth.uid == userId || isSuperAdmin());
    }

    match /clients/{clientId} {
      allow read, write: if request.auth != null && (resource.data.lawyerId == request.auth.uid || isSuperAdmin());
      allow create: if request.auth != null;
    }

    match /cases/{caseId} {
      allow read, write: if request.auth != null && (resource.data.lawyerId == request.auth.uid || isSuperAdmin());
      allow create: if request.auth != null;
    }

    match /documents/{docId} {
      allow read, write: if request.auth != null && (resource.data.userId == request.auth.uid || isSuperAdmin());
      allow create: if request.auth != null;
    }

    match /invoices/{invoiceId} {
      allow read, write: if request.auth != null && (resource.data.userId == request.auth.uid || isSuperAdmin());
      allow create: if request.auth != null && isPremiumUser();
    }

    match /aiHistory/{chatId} {
      allow read, write: if request.auth != null && (resource.data.userId == request.auth.uid || isSuperAdmin());
      allow create: if request.auth != null && isPremiumUser();
    }

    match /{document=**} {
      allow read, write: if isSuperAdmin();
    }
  }
}
